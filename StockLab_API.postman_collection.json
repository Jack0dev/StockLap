						"auth": { "type": "noauth" },
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"newuser\",\n    \"email\": \"newuser@stocklab.vn\",\n    \"password\": \"user123\",\n    \"fullName\": \"Nguyen Van Moi\",\n    \"phone\": \"0901234567\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
